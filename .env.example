# Database — Prisma Postgres connection string
# Get one at: https://prisma.io/postgres (npx create-db)
# Use sslmode=verify-full (not require) to avoid pg sslmode deprecation warnings.
DATABASE_URL=

# better-auth — generate a random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public URL of the app (no trailing slash) — used by server and client
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth — for login
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Dedicated secret for encrypting workspace PATs stored in DB (recommended; dev may fall back to BETTER_AUTH_SECRET).
# In production, saving a workspace GitHub token requires this to be set (see lib/github/encrypt-token.ts).
# GITHUB_TOKEN_ENCRYPTION_KEY=

# Vault repo webhook — auto-sync mirror when someone pushes to GitHub (incl. Obsidian Git)
# Production Payload URL: {BETTER_AUTH_URL}/api/webhook/github
# Local dev: use smee.io channel URL in GitHub, run `npm run dev:smee` in a second terminal
# Generate secret: openssl rand -hex 32 (must match GitHub webhook secret)
GITHUB_WEBHOOK_SECRET=

# Client: webhook UI polling interval (12s default). Set false for local dev without webhook (30s poll + focus check).
# NEXT_PUBLIC_VAULT_WEBHOOK_ENABLED=false

# smee.io (local only) — https://smee.io/me-hub-vault-git-sync
SMEE_SOURCE_URL=https://smee.io/me-hub-vault-git-sync
SMEE_TARGET_URL=http://localhost:3000/api/webhook/github

# MCP (Claude Code / Cursor) — copy API key from Workspace → Einstellungen → MCP
# MEHUB_MCP_API_KEY=mhub_...
# Optional: restrict CORS on `/.well-known/oauth-protected-resource` (comma-separated origins). Omit for library defaults.
# MCP_RESOURCE_CORS_ORIGINS=http://127.0.0.1:3845

# Vault sync diagnostics in production stdout (normally only in NODE_ENV=development)
# SYNC_LOG_VERBOSE=1
